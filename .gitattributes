# Normalize line endings: text files are stored as LF in the repo and checked
# out as LF on every platform. This keeps Prettier's `format:check` consistent
# on Windows (where core.autocrlf would otherwise yield CRLF working copies).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.jar binary
*.keystore binary
*.jks binary
